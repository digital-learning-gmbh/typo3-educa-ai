  "description": "Berechnet SEO-Daten mittels Planer-Task und Button, potenziell mit KI-Unterstützung.",
  "authors": [
    {
      "name": "Benjamin Ledel",
      "role": "Developer"
    }
  ],
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.2",
    "typo3/cms-core": "^12.4 || ^13.4",
    "typo3/cms-backend": "^12.4 || ^13.4"
  },
  "autoload": {
    "psr-4": {
      "EducaAiTypo3Seo\\EducaAiTypo3Seo\\": "Classes/"
    }
  },
  "extra": {
    "typo3/cms": {
